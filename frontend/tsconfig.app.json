{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode — no baseUrl needed; Vite handles runtime resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict type checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "erasableSyntaxOnly": true,

    /*
     * @/* path aliases for IDE intelligence.
     * With moduleResolution="bundler" (TS 5+), "paths" does NOT require
     * "baseUrl" — that rule only applied to the legacy "node" strategy.
     * Runtime resolution is handled by vite.config.ts resolve.alias.
     */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
