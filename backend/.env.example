# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5050

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/xeno_crm
# Production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/xeno_crm?retryWrites=true&w=majority

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Local:
REDIS_URL=redis://localhost:6379
# Production — Upstash Redis (recommended for Render):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
#
# Production — Render Redis (if using Render's managed Redis):
# REDIS_URL=<from Render dashboard > Environment > REDIS_URL>

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_secret_in_production

# ─── Service URLs ──────────────────────────────────────────────────────────────
# Local:
FRONTEND_URL=http://localhost:5173
CHANNEL_SERVICE_URL=http://localhost:5001
# Production (set these in Render dashboard):
# FRONTEND_URL=https://your-frontend.vercel.app
# CHANNEL_SERVICE_URL=https://xeno-channel-service.onrender.com

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
